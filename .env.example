# Application
APP_NAME="Bhatti Export Documents"
APP_URL=http://localhost:8080
APP_ENV=local
APP_DEBUG=true
# Production: set APP_ENV=production, APP_DEBUG=false, APP_ALLOW_INSTALL=false
# APP_ALLOW_INSTALL=true  # only when you must re-run install.php once

# Database (Docker defaults; change for shared hosting)
DB_HOST=db
DB_PORT=3306
DB_NAME=bhatti_accounts
DB_USER=bhatti
DB_PASS=bhatti_secret

# Authorized users (comma-separated emails for OTP login)
AUTHORIZED_EMAILS=admin@example.com,accounts@example.com

# SMTP — Docker local: MailHog (http://localhost:8025)
# Production / shared hosting: use real SMTP (Gmail, etc.)
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_AUTH=false
MAIL_FROM_ADDRESS=noreply@bhatti.local
MAIL_FROM_NAME="Bhatti Export Documents"

# Production example (uncomment and replace MailHog settings above):
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_ENCRYPTION=tls
# MAIL_AUTH=true
# MAIL_FROM_ADDRESS=your-email@gmail.com

# OTP
OTP_EXPIRY_MINUTES=15
OTP_LENGTH=6

# Session
SESSION_LIFETIME=7200
